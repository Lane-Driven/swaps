#!/usr/bin/env bash

# Swap's Manager
# Lane Maynor

swapdir="$HOME/.local/state/nvim-vim-pack/swap"

usage() {
	local exit_status=0
	if [[ "$1" == "fail" ]]; then
		exit_status=1
	fi
	echo "Usage: swaps [-h] [-d file]"
	echo "  -h            Display help."
	echo "  -d file       Delete a swap file."
	echo "  -A            Delete all files in swap directory."
	exit "$exit_status"
}

default_swaps() {
	mapfile -t files < <(ls -tr "$swapdir")

	if (( ${#files[@]} == 0 )); then
		echo "No files in swap directory."
	else
		for file in "${files[@]}"; do
			echo "$file"
		done
	fi
}

del_all_files_in_swapdir() {
	mapfile -t files < <(find "$swapdir" -type f -iname "*")
	local count="${#files[@]}"
	
	if (( count == 0 )); then
		echo "No files in swap directory."
		return
	else
		read -r -p "Delete all files in swap? ($count files) (y/N)" response
		case "$response" in
			[yY][eE][sS]|[yY])
				rm "${files[@]}"
				;;
			*)
				echo "Canceled"
				return
				;;
		esac
	fi
	echo "$count files deleted."
}

del_swap_file() {
	local file="$1"
	mapfile -t files < <(find "$swapdir" -type f -iname "*${file}*")

	if (( ${#files[@]} == 0 )); then
		echo "No files have the name $file"
		exit 1
	else
		local files_deleted=0

		if (( ${#files[@]} == 1 )); then
			local path="${files[0]}"
			local name="${path##*/}"
			echo "Found 1 file."
			read -r -p "Delete $name? (y/N): " response
			case "$response" in
				[yY][eE][sS]|[yY])
					rm "$path"
					((files_deleted++))
					;;
				*)
					echo "Canceled"
					return
					;;
			esac
		else
			local -A path_map

			for path in "${files[@]}";do
				local shortname="${path##*/}"
				path_map["$shortname"]="$path"
			done

			local ps3_old="$PS3"
			PS3="Choose a file: "
			select shortname in "${!path_map[@]}" "exit"; do
				if [[ "$shortname" == "exit" ]]; then
					return
				elif [[ -n "$shortname" ]]; then
					local fullpath="${path_map[$shortname]}"
					read -r -p "Delete $shortname? (y/N): " response
					case "$response" in
						[yY][eE][sS]|[yY])
							rm "$fullpath"
							((files_deleted++))
							break
							;;
						*)
							echo "Canceled"
							break
							;;
					esac
				else
					echo "Invalid selection"
				fi
			done
			PS3="$ps3_old"
		fi

		if (( files_deleted > 0 )); then
			echo "$files_deleted files deleted."
		fi
	fi
	exit 0
}

diff_this() {
	local file="$1"
    mapfile -t paths < <(find "$swapdir" -type f -iname "*${file}*")
	
	local count="${#paths[@]}"
	if (( count == 0 )); then
		echo "No files have the name $file"
		exit 1
	elif (( count == 1 )); then
		local target="${paths[0]}"
		diff $file $target | bat
		exit 0
	else
		declare -A path_map
		local short
		
		for path in "${paths[@]}"; do
			short="${path##*/}"
			path_map["$short"]="$path"
		done

		local old_ps3="$PS3"
		PS3="Choose a file: "
		select shortname in "${!path_map[@]}" "exit"; do
			if [[ "$shortname" == "exit" ]]; then
				return	
			elif [[ -n "$shortname" ]]; then
				local todiff="${path_map[$shortname]}"
				echo "Comparing $todiff"
				diff "$file" "$todiff" | bat
				return
			else
				echo "Invalid selection"
			fi
		done
		PS3="$ps3_old"
	fi
}

swaps() {

	if [ $# -eq 0 ]; then
		default_swaps 
	fi

	while getopts ":hd:r:A" opt; do
		case "${opt}" in
			h)
				usage; ;;
			d)
				diff_this "${OPTARG}"
				;;
			r)
				del_swap_file "${OPTARG}"
				;;
			A)
				del_all_files_in_swapdir
				;;
			\?)
				echo "Invalid option: -${OPTARG}" >&2
				usage "fail"
				;;
			:)
				echo "Option -${OPTARG} requires a file name"
				exit 1
				;;
		esac
	done
	shift $(( OPTIND - 1 ))
	if [[ -n "$1" ]]; then
		echo "Unexpected argument: $1"
		usage "fail"
	fi
}

swaps "$@"
